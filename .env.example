# CTA Bus Tracker API key — get one at https://www.ctabustracker.com/home
# Used by scripts/build-index.js to fetch bus pattern geometry.
CTA_BUS_KEY=your-key-here

# Cloudflare Worker base URL for cross-device ridden-routes sync.
# Deploy from worker/ (`npm --prefix worker install`, then `cd worker && npx
# wrangler deploy`), then put the resulting
# https://<worker>.<subdomain>.workers.dev URL here. Vite bakes it into the
# client bundle at build time (so it's public — not a secret; the per-device
# random sync key is what protects data). CI sets it in deploy.yml's build step.
VITE_SYNC_URL=https://your-worker.your-subdomain.workers.dev
